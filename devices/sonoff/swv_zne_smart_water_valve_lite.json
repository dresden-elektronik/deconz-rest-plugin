{
  "schema": "devcap1.schema.json",
  "uuid": "d3d5f8d8-8c3c-4e4c-9f1f-9c6d6c3f2a11",
  "manufacturername": "SONOFF",
  "modelid": "SWV-ZNE",
  "vendor": "Sonoff",
  "product": "Hydro ONE Lite smart water valve",
  "sleeper": true,
  "status": "Gold",
  "subdevices": [
    {
      "type": "$TYPE_ON_OFF_OUTPUT",
      "restapi": "/lights",
      "uuid": [
        "$address.ext",
        "0x01"
      ],
      "items": [
        { "name": "attr/id" },
        { "name": "attr/lastannounced" },
        { "name": "attr/lastseen" },
        { "name": "attr/manufacturername" },
        { "name": "attr/modelid" },
        { "name": "attr/name" },
        { "name": "attr/swversion" },
        { "name": "attr/type" },
        { "name": "attr/uniqueid" },
        { "name": "state/reachable" },
        { "name": "state/on" }
      ]
    },
    {
      "type": "$TYPE_BATTERY_SENSOR",
      "restapi": "/sensors",
      "uuid": [
        "$address.ext",
        "0x01",
        "0x0001"
      ],
      "items": [
        { "name": "attr/id" },
        { "name": "attr/lastannounced" },
        { "name": "attr/lastseen" },
        { "name": "attr/manufacturername" },
        { "name": "attr/modelid" },
        { "name": "attr/name" },
        { "name": "attr/swversion" },
        { "name": "attr/type" },
        { "name": "attr/uniqueid" },
        {
          "name": "config/battery",
          "parse": {
            "fn": "zcl:attr",
            "ep": 1,
            "cl": "0x0001",
            "at": "0x0021",
            "eval": "var bat = Attr.val; if (bat == 255) { bat = 0; } else { bat = Math.round(bat / 2); if (bat > 100) { bat = 100; } else if (bat < 0) { bat = 0; } } Item.val = bat;"
          },
          "read": {
            "fn": "zcl:attr",
            "ep": 1,
            "cl": "0x0001",
            "at": "0x0021"
          },
          "awake": true
        },
        { "name": "config/on" },
        { "name": "config/reachable" },
        { "name": "state/battery" },
        { "name": "state/lastupdated" }
      ]
    }
  ],
  "bindings": [
    {
      "bind": "unicast",
      "src.ep": 1,
      "cl": "0x0001",
      "report": [
        {
          "at": "0x0021",
          "dt": "0x20",
          "min": 3600,
          "max": 86400,
          "change": "0x02"
        }
      ]
    },
    {
      "bind": "unicast",
      "src.ep": 1,
      "dst.ep": 1,
      "cl": "0x0006",
      "report": [
        {
          "at": "0x0000",
          "dt": "0x10",
          "min": 1,
          "max": 300
        }
      ]
    }
  ]
}
