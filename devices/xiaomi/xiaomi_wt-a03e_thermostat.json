            "ep": "0x01",
            "cl": "0xFCC0",
            "mf": "0x115F",
            "at": "0x00EE",
            "eval": "Item.val = '0.0.0_' + ('0000' + ((Attr.val & 0xFF00) >> 8).toString() + (Attr.val & 0xFF).toString()).slice(-4)"
          },
          "read": {
            "fn": "zcl:attr",
            "ep": "0x01",
            "cl": "0xFCC0",
            "mf": "0x115F",
            "at": [
              "0x00EE"
            ]
