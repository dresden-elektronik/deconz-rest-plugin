          },
          "parse": {
            "at": "0x0330",
            "cl": "0xFCC0",
            "ep": 1,
            "eval": "Item.val = Attr.val",
            "fn": "zcl:attr",
            "mf": "0x115f"
          },
          "write": {
            "at": "0x0330",
            "cl": "0xFCC0",
            "dt": "0x20",
            "ep": 1,
            "eval": "if (Item.val == true) { 1 } else { 0 }",
            "fn": "zcl:attr",
            "mf": "0x115f"
          },
