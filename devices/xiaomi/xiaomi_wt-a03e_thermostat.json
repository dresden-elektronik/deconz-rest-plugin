          "read": {
            "at": "0x0277",
            "cl": "0xFCC0",
            "ep": 1,
            "fn": "zcl:attr",
            "mf": "0x115f"
          },
          "parse": {
            "at": "0x0277",
            "cl": "0xFCC0",
            "ep": 1,
            "eval": "Item.val = Attr.val",
            "fn": "zcl:attr",
