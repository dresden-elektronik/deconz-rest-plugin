            "cl": "0xFCC0",
            "ep": 1,
            "eval": "Item.val = ['off', 'heat'][Attr.val];",
            "fn": "zcl:attr",
            "mf": "0x115f"
          },
          "write": {
            "at": "0x0271",
            "cl": "0xFCC0",
            "dt": "0x20",
            "ep": 1,
            "eval": "if (Item.val == 'off') { 0 } else if (Item.val == 'heat') { 1 }",
            "fn": "zcl:attr",
            "mf": "0x115f"
          }
        },
        {
          "name": "config/reachable"
