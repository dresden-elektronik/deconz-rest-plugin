          },
          "write": {
            "dpid": 107,
            "dt": "0x10",
            "eval": "Item.val == 1 ? 1 : 0;",
            "fn": "tuya"
          },
          "parse": {
            "dpid": 107,
            "eval": "Item.val = Attr.val",
