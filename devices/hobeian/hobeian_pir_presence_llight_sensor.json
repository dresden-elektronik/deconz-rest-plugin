          },
          "write": {
            "fn": "tuya",
            "dpid": 122,
            "dt": "0x30",
            "eval": "if (Item.val == 'only pir') { 0 } else if (Item.val == 'pir and radar') { 1 } else { 'only radar' }"
          },
          "values": [
            [
              "only pir",
              0
            ],
            [
              "pir and radar",
              1
            ],
            [
              "only radar",
              2
            ]
          ],
          "default": "pir and radar"
        },
